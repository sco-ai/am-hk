# 环境变量配置模板
# 复制为 .env 使用

# ============================================
# 服务端口配置（禁止修改！）
# ============================================
API_PORT=8020
POSTGRES_PORT=5452
REDIS_PORT=6399
KAFKA_PORT=9112
ZOOKEEPER_PORT=2201
KAFKA_UI_PORT=8100

# ============================================
# 数据库配置
# ============================================
POSTGRES_HOST=localhost
POSTGRES_DB=alphamind_hk
POSTGRES_USER=am_hk_user
POSTGRES_PASSWORD=changeme_in_production

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PASSWORD=

# ============================================
# Kafka 配置
# ============================================
KAFKA_HOST=localhost
KAFKA_ZOOKEEPER_CONNECT=localhost:2201

# ============================================
# 应用配置
# ============================================
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=generate_a_strong_secret_key_here

# ============================================
# 外部服务
# ============================================
